</script>		<style id="wp-custom-css">
			.hero-band {
    height: 82vh !important; /* 你可以改成 70vh / 80vh */
    max-height: 82vh !important;
    position: relative !important;
    overflow: hidden !important;
}
/* Swiper 高度同步 */
.hero-band .swiper-container,
.hero-band .swiper-wrapper,
.hero-band .swiper-slide {
    height: 82vh !important;
    overflow: hidden !important;
}

/* 视频与图片统一裁切铺满 */
.hero-band video,
.hero-band .swiper-slide img {
    width: 100% !important;
    height: 100% !important;
    min-height: 100% !important;
    object-fit: cover !important; /* 关键：保持高度一致 */
    object-position: center !important;
}

/* ------------------------------
   蓝色背景框（hero-cont）重新定位成中间卡片
------------------------------ */

/* 蓝色卡片内文字颜色 */
.home .hero-band .hero-cont span,
.home .hero-band .hero-cont .feature-list,
.home .hero-band .hero-cont .btnrow {
    color: #fff !important;
}

 /* 下面是蓝框的位置 */
.home .hero-band .hero-cont {
    position: absolute !important;
	 /* 垂直居中 */
    top: 30% !important;         
	 /*固定靠右 */
    right: 3% !important;         
    left: auto !important;        /* 移除 left 冲突 */
    transform: translateY(-50%) !important; /* 只垂直居中，不做水平偏移 */

    background-color: rgba(0, 102, 170, 0.) !important;
    padding: 30px 3px !important;

    width: 54% !important;
    max-width: 830px !important;
    height: auto !important;

    border-radius: 4px;
    z-index: 5 !important;

    /* 强立体感阴影（可选） */
  box-shadow:
  0px 12px 25px rgba(0, 0, 0, 0.25),
  0px 20px 40px rgba(0, 0, 0, 0.15) !important;
}

/* 大标题Engineered Access Systems */
.hero-cont .headline {
    font-size: 42px !important;       /* 大气标题字号 */
    line-height: 0.6 !important;     /* 紧凑专业 */
    font-weight: 800 !important;

    text-transform: uppercase !important;
    letter-spacing: 0.8px !important;
    text-align:left !important;
    margin-bottom: 0px !important;
    padding: 0 80px 0 0;
	 /* 下面一句是调第一行的左右位置 */
	   margin-left: -10px;
    white-space: nowrap !important;   /* 强制一行 */
}

.hero-cont .headline {
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
}

/* 更强立体感标题阴影 */
.hero-cont .headline {
    text-shadow:
        0px 3px 4px rgba(0, 0, 0, 0.35),
        0px 6px 12px rgba(0, 0, 0, 0.25),
        0px 12px 18px rgba(0, 0, 0, 0.15) !important;
}

/* 列表文字更大、更清晰、更优雅 */
.hero-cont .feature-list {
    font-size: 25px !important;    /* 你现在的图示非常适合 20px */
    line-height: 1.65 !important;  /* 大气的行距 */
    font-weight: 400 !important;

    text-align: left !important;
    margin: 0 auto !important;
    width: 85% !important;         /* 列表不要太宽，更高端 */
}

/* 每行之间增加分隔距离 */
.hero-cont .feature-list br {
    margin-bottom: 6px !important;
    display: block;
    content: "";
}

.text_left {
    margin-top: 10px !important;
    margin-bottom: 5px !important;
    display: block !important; /* 非常重要：确保 margin 能生效 */
}

.text_left + ul li {
    line-height: 1.6 !important;   /* 1.6–1.8 都会很好看 */
    margin-bottom: 6px !important; /* 可选：增加底部空间 */
}

/* 隐藏黄线 */
.hero-cont .headline:before,
.hero-cont .headline:after,
.hero-cont .headline hr,
.hero-cont .headline .underline {
    display: none !important;
}
/* 手机 */
@media (max-width: 768px) {
  .home .hero-band .s1 {
    white-space: normal !important;
    text-align: center;
  }
}

/* 主页 Services 那六张图 */
.services-band .row2 .col p {
    position: absolute !important;
    left: 50%;
    bottom: 20px;                  /* ⭐ 距离底部 */
    transform: translateX(-50%); !important;

    background: none !important;
    border: none !important;
    padding: 0 !important;

    color: #fff !important;
    font-weight: 600;
    font-size: 22px;
    line-height: 1.35;
    letter-spacing: 0.6px;
    text-align: center;

    text-shadow: 0 6px 16px rgba(0, 0, 0, 0.45);
}

.services-band .row2 .col img {
    transition: transform 0.3s ease;
}

.services-band .row2 .col:hover img {
    transform: scale(1.02);
}


/* ===============================
   手机端：彻底重置 Hero 布局
=============================== */
@media (max-width: 768px) {

  /* 1️⃣ Hero 整体高度交给内容决定 */
  .hero-band {
    height: auto !important;
    max-height: none !important;
  }

  /* 2️⃣ 图片 / 视频恢复正常宽高 */
  .hero-band .swiper-container,
  .hero-band .swiper-wrapper,
  .hero-band .swiper-slide {
    height: auto !important;
  }

  .hero-band video,
  .hero-band .swiper-slide img {
    height: auto !important;
    min-height: unset !important;
    aspect-ratio: 16 / 9;
  }

  /* 3️⃣ ⭐ 关键：蓝色块取消绝对定位 */
  .home .hero-band .hero-cont {
    position: relative !important;
    top: auto !important;
    right: auto !important;
    left: auto !important;
    transform: none !important;

    width: 100% !important;
    max-width: 100% !important;

    padding: 24px 16px !important;
    margin: 0 !important;

    border-radius: 0 !important;
  }

  /* 4️⃣ 标题 & 文案正常显示 */
  .hero-cont .headline {
    white-space: normal !important;
    text-align: center !important;
    margin-left: 0 !important;
    padding: 0 !important;
    font-size: 28px !important;
    line-height: 1.2 !important;
  }

  .hero-cont .feature-list {
    width: 100% !important;
    text-align: center !important;
    font-size: 18px !important;
    line-height: 1.6 !important;
  }

  /* 5️⃣ 按钮居中 */
  .hero-cont .btn-row {
    justify-content: center !important;
    flex-direction: column;
    gap: 12px;
  }
}
@media (max-width: 768px) {
  .home .hero-band .hero-cont .btn-row {
    margin-top: 1px !important; /* 原来是 35px，太大了 */
  }
}
@media (max-width: 768px) {
  .home .hero-band .feature-list {
    margin-bottom: 0 !important;
  }
}
/* =========================
   HERO 按钮（桌面 + 手机通用）
========================= */

/* 桌面：按钮跟随蓝色框 */
.home .hero-band .hero-cont .btn-row {
  display: flex;
  gap: 20px;
  margin-top: 28px;      /* 与文案距离 */
  justify-content: flex-start;
}

.home .hero-band .hero-cont .btn-row a {
  display: inline-flex;
  justify-content: center;
  align-items: center;

  min-width: 220px;
  padding: 12px 36px;
  box-sizing: border-box;
}

/* ===============================
   MOBILE CTA — 密度 B（推荐）
=============================== */
@media (max-width: 768px) {

  /* 1️⃣ 按钮组之间的距离（核心） */
  .hero-cont .btn-row {
    gap: 1px !important;        /* 原来 12px → 8px */
    margin-top: 6px !important; /* 原来 ~1px / 12px → 稍微贴近文案 */
  }

  /* 2️⃣ 单个按钮“厚度”收紧 */
  .hero-cont .btn-row a {
    padding: 4px 14px !important; /* 原来 12px+ → 稍微收 */
    line-height: 1.25 !important;
  }

  /* 3️⃣ 蓝框底部留白同步收紧 */
  .home .hero-band .hero-cont {
    padding-bottom: 8px !important; /* 原来 24px */
  }
}

.s1 {
  display: inline-block;
  white-space: nowrap;
}

@media (max-width: 768px) {
  .s1 {
    display: block !important;
    white-space: normal !important;
    text-align: center !important;
    line-height: 1.4 !important;
  }

  .s1 br {
    display: block !important;
    content: "" !important;
    margin-top: 6px;
  }
}
/*下拉框右边的方框去掉*/
.menu-item-has-children::before,
.menu-item-has-children::after,
.menu-item-has-children > a::before,
.menu-item-has-children > a::after {
  color: transparent !important;
}



/*Logo 同一排*/
.bot-header .row {
    flex-wrap: nowrap !important;
}
.bot-header a.logo {
    flex-shrink: 0;
    margin-right: 30px;
}
.bot-header nav {
    flex: 1 1 auto;
    white-space: nowrap;
}
.bot-header .header-button,
.bot-header .btn,
.bot-header a.button {
    flex-shrink: 0;
}
/* 让 logo 更靠左 */
.bot-header a.logo {
    margin-left: -260px;
}

/* 控制 logo 与 menu 的距离 */
.bot-header a.logo {
    margin-right: 20px;
}

/*Contact 往右靠*/
.bot-header a.button,
.bot-header .header-button,
.bot-header .btn {
    margin-left: auto;
    margin-right: -260px;
}






		</style>
		</head>

