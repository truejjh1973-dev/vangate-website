			<script>
(function () {
  let fired = false;

  const checkInterval = setInterval(function () {
    if (fired) return;

    const bodyText = document.body.innerText || '';

    if (bodyText.includes('Thank you for your message')) {
      fired = true;
      clearInterval(checkInterval);

      if (typeof gtag === 'function') {
        gtag('event', 'conversion', {
          'send_to': 'AW-17800033103/eUcVCIYytEbM_m26dC',
          'value': 1.0,
          'currency': 'CAD'
        });

        console.log('✅ Contact form conversion fired');
      } else {
        console.warn('⚠️ gtag not found');
      }
    }
  }, 500); // 每 0.5 秒检查一次
})();
</script><!-- Google tag (gtag.js) -->
